# ============================================
# Root .gitignore for DisasterNett
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest / linters
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ---------- Node / Frontend ----------
node_modules/
dist/
dist-ssr/
build/
*.local
.cache/
.parcel-cache/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Environment / Secrets ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------- ML / Data (large files) ----------
*.h5
*.hdf5
*.pkl
*.joblib
*.npy
*.npz
*.pt
*.pth
*.onnx
*.pb
*.tflite
*.safetensors
data/
artifacts/
models/
!models/.gitkeep
*.csv
!**/configs/*.csv

# DVC local cache
.dvc/cache/
.dvc/tmp/

# Forecasting model state & logs
.logs/
.state/

# ---------- Archives ----------
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ---------- Editor / OS ----------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- Docker ----------
*.pid

# ---------- Misc ----------
*.bak
*.tmp
*.temp
